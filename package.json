{
  "name": "my-polymkt-terminal",
  "version": "0.1.0",
  "description": "Maker-merge market-making bot for Polymarket 5m/15m crypto Up-or-Down markets. Posts maker-only buy orders on both YES and NO under a combined price cap, merges filled pairs back into USDC, and logs both-fill-rate KPIs.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "dev:sim": "DRY_RUN=true tsx watch src/index.ts",
    "dev:sim:5m": "DOTENV_CONFIG_PATH=.env.5m DRY_RUN=true tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:sim": "DRY_RUN=true node dist/index.js",
    "kpi-report": "tsx src/scripts/kpiReport.ts",
    "kpi-report:5m": "DOTENV_CONFIG_PATH=.env.5m tsx src/scripts/kpiReport.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "4.22.8",
    "dotenv": "^17.4.2",
    "ethers": "^5.7.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
