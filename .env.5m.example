# ─────────────────────────────────────────────────────────────────────────
# 5-MINUTE PROFILE — experimental. For comparing both-fill rate against the
# 15m baseline before considering 5m for real trading (see README's
# "5-minute markets" section for why the timing values below differ from
# .env.example).
#
# Copy this file to .env.5m (NOT .env — that stays your 15m baseline):
#   cp .env.5m.example .env.5m
# Then run with:
#   npm run dev:sim:5m       # dry-run against this profile
#   npm run kpi-report:5m    # both-fill rate for this profile's own log
# Both scripts set DOTENV_CONFIG_PATH=.env.5m so your main .env is untouched.
# ─────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────
# Wallet (required to go live; optional while DRY_RUN=true)
# ─────────────────────────────────────────────────────────────────────────
# EOA private key that signs orders/transactions. For DRY_RUN you can use a
# brand-new throwaway wallet (e.g. `node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"`)
# — it never needs funds in sim mode, it's only used to authenticate reads.
PRIVATE_KEY=

# Your Polymarket account address (the proxy wallet that holds your USDC,
# shown in the Polymarket app under your profile / deposit address).
PROXY_WALLET_ADDRESS=

# How your Polymarket account signs orders on your behalf:
#   2 = POLY_GNOSIS_SAFE  -> standard email / Magic-link Polymarket accounts (most users)
#   1 = POLY_PROXY        -> accounts created by connecting MetaMask directly
#   0 = EOA                -> raw wallet trading directly on the CLOB (not supported by this bot)
# If unsure, you almost certainly want 2.
SIGNATURE_TYPE=2

# ─────────────────────────────────────────────────────────────────────────
# Polygon RPC (only needed for live split/merge/redeem on-chain calls)
# ─────────────────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ─────────────────────────────────────────────────────────────────────────
# CLOB API credentials — leave blank to auto-derive from PRIVATE_KEY on boot
# ─────────────────────────────────────────────────────────────────────────
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ─────────────────────────────────────────────────────────────────────────
# Safety switch — keep true until you've watched real KPI logs and trust them
# ─────────────────────────────────────────────────────────────────────────
DRY_RUN=true

# ─────────────────────────────────────────────────────────────────────────
# Maker-Merge MM strategy
# ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of crypto assets to trade. Each maps to Polymarket's
# "{asset}-updown-{duration}-{eventStartTimestamp}" market slug family.
# Only btc/eth are enabled right now (see SUPPORTED_ASSETS in src/config.ts and
# the README's Asset selection section) — sol/xrp will throw a config error
# until that list is deliberately edited.
MM_ASSETS=btc,eth

# Market duration family: 5m or 15m — this profile exists specifically to test 5m.
MM_DURATION=5m

# Shares to buy per side, per cycle (NOT USDC — both sides must hold equal share
# counts so the pair can be merged 1:1). CLOB enforces a 5-share minimum order size.
MM_TRADE_SIZE=5

# Cap on (yesBid + noBid). This is your edge: 1 - MM_MAX_COMBINED is the
# spread you capture per successful both-fill merge, before fees.
MM_MAX_COMBINED=0.98

# Only enter when both sides' best bid lands inside this band — keeps you
# out of markets that have already swung heavily to one side.
MM_MIN_PRICE=0.30
MM_MAX_PRICE=0.69

# Seconds after market open during which we're allowed to place the entry
# orders (the post-open stabilization delay is fixed at 10s internally).
# Tightened vs. the 15m default (45s): a 300s market can't afford to spend
# the same absolute number of seconds on entry as a 900s one — that would
# eat ~18% of the window vs. ~5% on 15m. 20s keeps the proportion closer
# to the 15m baseline (10+20=30s is 10% of 300s).
MM_ENTRY_WINDOW_SEC=20

# Seconds before market close: force-exit any open exposure no matter what.
# Tightened vs. the 15m default (60s) for the same reason — 60s on a 300s
# market reserves 20% of the window for cut-loss vs. ~7% on 15m. 25s keeps
# that proportion closer to the 15m baseline.
MM_CUT_LOSS_SEC=25

# Re-entry behavior once a cycle ends with both sides filled. Left at the
# 15m defaults for now — worth experimenting with a shorter delay once you
# have baseline KPI numbers to compare against.
MM_REENTRY_ENABLED=true
MM_REENTRY_DELAY_SEC=30

# If re-entering into a market that's already running, skip it when either
# side's odds have drifted past this (no point chasing a decided outcome).
CURRENT_MARKET_ENABLED=true
CURRENT_MARKET_MAX_ODDS=0.70

# Strategy loop poll interval (position monitoring) and detector poll interval
# (how often we check Gamma API for the next market slot).
MM_POLL_SEC=3
MM_DETECTOR_POLL_SEC=5

# ─────────────────────────────────────────────────────────────────────────
# KPI logging — separate file from the 15m profile's log, so kpi-report
# never mixes the two durations' cycles together.
# ─────────────────────────────────────────────────────────────────────────
KPI_LOG_PATH=logs/cycles-5m.jsonl

# ─────────────────────────────────────────────────────────────────────────
# Dashboard — separate port from the 15m profile's dashboard (3000), so you
# can run both .env and .env.5m bots side by side, each with its own UI.
# ─────────────────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3001
DASHBOARD_HOST=127.0.0.1
